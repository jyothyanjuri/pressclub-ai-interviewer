# PressClub AI Interviewer — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# Claude API — research agent + synthesis agent
ANTHROPIC_API_KEY=

# Vapi — voice orchestration + assistant creation
VAPI_API_KEY=
# Vapi public key for browser SDK (safe to expose in frontend)
VAPI_PUBLIC_KEY=

# Gemini — LLM inside Vapi (built-in Vapi provider)
GEMINI_API_KEY=

# Oxylabs — LinkedIn profile scraping
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# OpenAI — Whisper audio transcription
OPENAI_API_KEY=

# Optional — Stretch Goal 1: Custom LLM URL
# Set to your publicly accessible FastAPI URL (e.g. ngrok tunnel in dev)
# If set, Vapi will call /chat/completions on this server for dynamic follow-ups.
# VAPI_CUSTOM_LLM_URL=https://your-tunnel.ngrok.io/chat/completions
